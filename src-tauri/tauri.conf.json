{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Ampersand",
  "version": "../package.json",
  "identifier": "moe.ampersand.track",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "yarn rsbuild dev",
    "beforeBuildCommand": "yarn build:rsbuild"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  },
  "bundle": {
    "active": true,
    "category": "Lifestyle",
    "resources": {
      "../assets/": ""
    },
    "targets": [
      "deb",
      "rpm",
      "appimage",
      "dmg",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/iconAssets.car",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "android": {
      "versionCode": 2366,
      "minSdkVersion": 29,
      "debugApplicationIdSuffix": ".debug"
    },
    "iOS": {
      "bundleVersion": "2366",
      "minimumSystemVersion": "18.6"
    },
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "bundleVersion": "2366",
      "minimumSystemVersion": "15.6",
      "signingIdentity": "-"
    },
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "silent": true,
        "type": "embedBootstrapper"
      },
      "minimumWebview2Version": "140.0.3415.0",
      "wix": {
        "version": "0.3.0.2366"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}